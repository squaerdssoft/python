def _get_yt_transcript(video_id: str) -> str | None:
    if not _TRANSCRIPT:
        return None
    try:
        tl = YouTubeTranscriptApi.list_transcripts(video_id)
        transcript = None
        try:
            transcript = tl.find_manually_created_transcript(["tr", "en", "de", "fr", "es"])
        except Exception:
            try:
                transcript = tl.find_generated_transcript(["tr", "en", "de", "fr", "es"])
            except Exception:
                for t in tl:
                    transcript = t
                    break
        if transcript is None:
            return None
        fetched = transcript.fetch()
        return " ".join(entry["text"] for entry in fetched)
    except Exception as e:
        logger.warning(f"Transkript alınamadı: {e}")
        return None

def _yt_summarize(transcript: str) -> str:
    if not _GENAI:

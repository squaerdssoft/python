    def _start_engine(self):
        self.root.deiconify()
        self._animate()
        self.root.protocol("WM_DELETE_WINDOW", lambda: os._exit(0))

    def _animate(self):
        self.tick += 1
        self._draw()
        self.root.after(30, self._animate)

    def _draw(self):
        c  = self.canvas
        c.delete("all")
        cx = self.W // 2
        cy = self.H // 2 - 80
        t  = self.tick

        # 1. ARKA PLAN IZGARA (Derinlik efekti için iki katman)
        spacing = 60
        offset  = (t % spacing)
        for i in range(-spacing, self.W + spacing, spacing):
            # Dikey çizgiler (kayan)
            c.create_line(i + offset, 0, i + offset, self.H, fill="#051529", width=1)
            # Yatay çizgiler
            c.create_line(0, i, self.W, i, fill="#051529", width=1)

        # 2. DIŞ SİNYAL HALKASI (Kesikli ve yavaş dönen)
        r_outer = 320
        c.create_oval(cx-r_outer, cy-r_outer, cx+r_outer, cy+r_outer, outline=C_GLOW, width=1)
        self._draw_arc_ring(cx, cy, r_outer + 5, t * 0.2, 20, C_SECONDARY, 1)
        self._draw_arc_ring(cx, cy, r_outer + 5, t * 0.2 + 180, 20, C_SECONDARY, 1)

        # 3. JARVIS HEXAGONAL HUD (Altıgenimsi yapı)
        r_hex = 280
        points = []
        for i in range(0, 360, 60):
            ang = math.radians(i + t * 0.1)
            px = cx + r_hex * math.cos(ang)
            py = cy + r_hex * math.sin(ang)
            points.append((px, py))
            # Köşelerde küçük veri noktaları
            c.create_oval(px-2, py-2, px+2, py+2, fill=C_SECONDARY, outline="")
        
        for i in range(len(points)):
            p1 = points[i]
            p2 = points[(i+1)%len(points)]
            c.create_line(p1[0], p1[1], p2[0], p2[1], fill=C_GLOW, width=1, dash=(2, 4))

        # 4. VERİ AKIŞ HALKASI (Dönen kodlar)
        r_data = 240
        for i in range(0, 360, 30):
            ang = math.radians(i - t * 0.8)
            x = cx + r_data * math.cos(ang)
            y = cy + r_data * math.sin(ang)
            txt = random.choice(["01", "AI", "JARVIS", "W", "Ω", "∑", "∞"])
            c.create_text(x, y, text=txt, fill=C_SECONDARY, font=("Consolas", 7), angle=-(i - t * 0.8))

        # 5. ANA ENERJİ HALKASI (Nabız atan altın sarısı)
        pulse = math.sin(t * 0.15) * 8
        r_core = 180 + pulse
        c.create_oval(cx-r_core, cy-r_core, cx+r_core, cy+r_core, outline=C_PRIMARY, width=2)
        # Dönel segmentler
        self._draw_arc_ring(cx, cy, r_core - 5, t * 2, 60, C_PRIMARY, 4)
        self._draw_arc_ring(cx, cy, r_core - 5, t * 2 + 180, 60, C_PRIMARY, 4)

        # 6. SES VİSÜALİZATÖRÜ (Merkezden dışa fışkıran barlar)
        r_inner = 130
        for i in range(0, 360, 6):
            ang = math.radians(i)
            # Eğer konuşuyorsa rastgele zıpla, konuşmuyorsa hafif dalgalan
            if self.speaking:
                h = random.randint(10, 60)
            else:
                h = 10 + math.sin(t * 0.1 + i * 0.5) * 10
            
            x1 = cx + r_inner * math.cos(ang)
            y1 = cy + r_inner * math.sin(ang)
            x2 = cx + (r_inner + h) * math.cos(ang)
            y2 = cy + (r_inner + h) * math.sin(ang)
            
            color = C_PRIMARY if h < 45 else C_ALERT
            c.create_line(x1, y1, x2, y2, fill=color, width=2)

        # 7. MERKEZ SEMBOL (V)
        pulse = math.sin(t * 0.15) * 8
        c.create_oval(cx-60, cy-60, cx+60, cy+60, fill=C_BG, outline=C_SECONDARY, width=2)
        c.create_text(cx, cy, text="V", fill=C_PRIMARY if not self.speaking else C_ALERT,
                      font=("Verdana", 42, "bold"))
        # Parlama halkası (V için geri getirildi)
        r_glow = 75 + pulse
        c.create_oval(cx-r_glow, cy-r_glow, cx+r_glow, cy+r_glow, outline=C_PRIMARY if not self.speaking else C_ALERT, width=1)
        # İç minik dönen element
        self._draw_arc_ring(cx, cy, 50, t * -4, 90, C_SECONDARY, 2)

        # 8. HUD BİLGİ PANELLERİ
        # Sol Üst: Sistem Kimliği
        c.create_text(50, 40, text="◈ Vesper PROTOCOL — NEURAL CORE v3.1",
                      fill=C_PRIMARY, font=("Verdana", 12, "bold"), anchor="w")
        c.create_line(50, 55, 350, 55, fill=C_PRIMARY, width=1)
        
        # Sağ Üst: Zaman ve Koordinat (Sahte)
        c.create_text(self.W-50, 40, text=time.strftime("%H:%M:%S"),
                      fill=C_PRIMARY, font=("Consolas", 16, "bold"), anchor="e")
        c.create_text(self.W-50, 60, text=f"LAT: 41.0082 | LON: 28.9784",
                      fill=C_SECONDARY, font=("Consolas", 8), anchor="e")

        # Sol Alt: Sensör ve Sağlık HUD
        hud_x, hud_y = 40, 100
        c.create_rectangle(hud_x, hud_y, hud_x+180, hud_y+110, outline=C_SECONDARY, width=1, fill="#051529")
        c.create_text(hud_x+10, hud_y+15, text="SİSTEM DURUMU", fill=C_SECONDARY, font=("Consolas", 8, "bold"), anchor="w")
        
        metrics = [
            (f"VISION: {self.visual_status}", C_PRIMARY if self.visual_status == "AWARE" else C_ALERT),
            (f"CORE: {self.health_status}", C_PRIMARY),
            (f"UPTIME: {t//30}s", C_SECONDARY),
            ("THREAT: 0.0%", C_SECONDARY)
        ]
        for i, (m, col) in enumerate(metrics):
            c.create_text(hud_x+15, hud_y+40 + (i*16), text=f"» {m}", fill=col, font=("Consolas", 8), anchor="w")

        # Sağ Alt: Grafik (Sahte)
        gx = self.W - 220
        gy = 100
        c.create_rectangle(gx, gy, gx+180, gy+110, outline=C_SECONDARY, width=1, fill="#051529")
        for i in range(10):
            vh = random.randint(5, 40)
            c.create_rectangle(gx + 10 + (i*16), gy+100, gx + 20 + (i*16), gy+100-vh, fill=C_GLOW, outline="")

        # 9. ALT DURUM VE MESAJLAR
        c.create_text(cx, 660, text=f"● {self.status_text}", fill=C_PRIMARY, font=("Consolas", 11, "bold"))
        bar_w = 400
        c.create_rectangle(cx-bar_w//2, 680, cx+bar_w//2, 683, fill=C_GLOW, outline="")
        progress = (t % 100) / 100
        c.create_rectangle(cx-bar_w//2, 680, (cx-bar_w//2) + (bar_w * progress), 683, fill=C_PRIMARY, outline="")

        # Log Terminali Yerleşimi
        lx, ly, lw, lh = 40, 710, self.W - 80, 160
        self.log_frame.place(x=lx, y=ly, width=lw, height=lh)

    def _draw_arc_ring(self, cx, cy, r, start_ang, extent, color, width):
        self.canvas.create_arc(cx-r, cy-r, cx+r, cy+r, start=start_ang, extent=extent,
                               outline=color, style="arc", width=width)
        self.canvas.create_arc(cx-r, cy-r, cx+r, cy+r, start=start_ang+180, extent=extent,
                               outline=color, style="arc", width=width)

    def write_log(self, text: str):
        self.typing_queue.append(text)
        if not self.is_typing:
            self._start_typing()

    def _start_typing(self):
        if not self.typing_queue:
            self.is_typing = False
            return
        self.is_typing = True
        line   = self.typing_queue.popleft()
        prefix = "»"
        if "Sen:"    in line: line = line.replace("Sen:", "[KULLANICI]"); prefix = "◈"
        if "Vesper:" in line: line = line.replace("Vesper:", "[VESPER]"); prefix = "❖"
        if "SYS:"    in line: line = line.replace("SYS:", "[SİSTEM]");   prefix = "⚠"
        self.log_text.configure(state="normal")
        self.log_text.insert(tk.END, f"\n{prefix} {line}")
        self.log_text.see(tk.END)
        self.log_text.configure(state="disabled")
        self.root.after(10, self._start_typing)

    def _on_chat_submit(self, event=None):
        text = self.chat_entry.get().strip()
        if text and text != "Komut yazın...":
            self.chat_entry.delete(0, tk.END)
            self.write_log(f"Sen: {text}")
            if self.core and self.core.session:
                asyncio.run_coroutine_threadsafe(
                    self.core.session.send_realtime_input(text=text),
                    self.core._loop
                )

    def _show_setup_ui(self, custom_msg=None):
        win = tk.Toplevel()
        win.title("Vesper — YETKİLENDİRME GEREKLİ")
        win.geometry("500x320")
        win.configure(bg=C_BG)
        win.resizable(False, False)
        win.attributes("-topmost", True)
        sw = win.winfo_screenwidth()
        sh = win.winfo_screenheight()
        win.geometry(f"500x320+{(sw-500)//2}+{(sh-320)//2}")

        tk.Label(win, text="◈ Vesper NEURAL IGNITION",
                 fg=C_PRIMARY, bg=C_BG, font=("Verdana", 14, "bold")).pack(pady=20)
        if custom_msg:
            tk.Label(win, text=custom_msg, fg=C_ALERT, bg=C_BG, font=("Consolas", 10, "bold")).pack()
        tk.Label(win, text="GEMİNİ API ANAHTARI GEREKLİ",
                 fg=C_TEXT, bg=C_BG, font=("Consolas", 9)).pack(pady=5)

        e = tk.Entry(win, width=40, show="*", bg="#05000a", fg=C_PRIMARY,
                     insertbackground=C_PRIMARY, font=("Consolas", 10))
        e.pack(pady=10)
        e.focus_set()

        def save(evt=None):
            key = e.get().strip()
            if key:
                try:
                    current_data = {}
                    if API_CONFIG_PATH.exists():
                        try:
                            with open(API_CONFIG_PATH, "r") as f:
                                current_data = json.load(f)
                        except Exception:
                            pass
                    current_data["gemini_api_key"] = key
                    VAULT_DIR.mkdir(parents=True, exist_ok=True)
                    with open(API_CONFIG_PATH, "w") as f:
                        json.dump(current_data, f)
                    win.destroy()
                    self._api_key_ready = True
                    self._start_engine()
                except Exception as ex:
                    messagebox.showerror("KASA HATASI", f"Kasa yazma hatası: {ex}")

        btn = tk.Button(
            win, text="[ Vesper'İ BAŞLAT ]", command=save,
            bg="#0a000f", fg=C_PRIMARY,
            activebackground=C_PRIMARY, activeforeground=C_BG,
            borderwidth=1, relief="flat", padx=20, pady=10
        )
        btn.pack(pady=20)
        win.bind("<Return>", save)
        win.protocol("WM_DELETE_WINDOW", lambda: os._exit(0))

    def start_speaking(self):
        self.speaking     = True
        self.status_text  = "VERİ AKIŞI AKTİF"

    def stop_speaking(self):
        self.speaking     = False
        self.status_text  = "SİNYAL BEKLENİYOR"

    def wait_for_api_key(self):
        while not self._api_key_ready:
            time.sleep(0.1)


    "Görseller":   [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp", ".svg", ".ico"],
    "Belgeler":    [".pdf", ".doc", ".docx", ".txt", ".xls", ".xlsx", ".ppt", ".pptx", ".csv"],
    "Videolar":    [".mp4", ".avi", ".mkv", ".mov", ".wmv", ".flv", ".webm"],
    "Müzik":       [".mp3", ".wav", ".flac", ".aac", ".ogg", ".wma"],
    "Arşivler":    [".zip", ".rar", ".7z", ".tar", ".gz"],
    "Kod":         [".py", ".js", ".html", ".css", ".json", ".xml", ".ts", ".cpp", ".java"],
    "Yürütülebilir": [".exe", ".msi", ".bat", ".cmd", ".sh"],
}

def _organize_desktop_files(mode: str = "by_type") -> str:
    desktop = Path.home() / "Desktop"
    moved   = []
    for item in desktop.iterdir():
        if item.is_dir() or item.name.startswith(".") or item.suffix.lower() == ".lnk":
            continue
        if mode == "by_date":
            mtime       = datetime.fromtimestamp(item.stat().st_mtime)
            folder_name = mtime.strftime("%Y-%m")
        else:
            ext         = item.suffix.lower()
            folder_name = "Diğer"
            for folder, exts in FILE_TYPE_MAP_DT.items():
                if ext in exts:
                    folder_name = folder
                    break
        target_dir = desktop / folder_name
        target_dir.mkdir(exist_ok=True)
        new_path = target_dir / item.name
        if not new_path.exists():
            shutil.move(str(item), str(new_path))
            moved.append(f"{item.name} → {folder_name}/")
    return f"Masaüstü düzenlendi. {len(moved)} dosya taşındı." + ("\n" + "\n".join(moved[:8]) if moved else "")

def _set_wallpaper(image_path: str) -> str:
    path = Path(image_path).expanduser().resolve()
    if not path.exists():
        return f"Görsel bulunamadı: {image_path}"
    try:
        if sys.platform == "win32":
            ctypes.windll.user32.SystemParametersInfoW(20, 0, str(path.resolve()), 3)
            return f"Duvar kağıdı ayarlandı: {path.name}"
        elif sys.platform == "darwin":
            script = f'tell application "Finder" to set desktop picture to POSIX file "{path}"'
            subprocess.run(["osascript", "-e", script])
            return f"Duvar kağıdı ayarlandı: {path.name}"
        else:
            subprocess.run(["gsettings", "set", "org.gnome.desktop.background", "picture-uri", f"file://{path}"])
            return f"Duvar kağıdı ayarlandı: {path.name}"
    except Exception as e:
        return f"Duvar kağıdı ayarlanamadı: {e}"

def _list_desktop() -> str:
    desktop = Path.home() / "Desktop"
    items   = []
    for item in sorted(desktop.iterdir()):
        if item.name.startswith("."):
            continue
        if item.is_dir():
            items.append(f"📁 {item.name}/")
        else:
            size = item.stat().st_size
            items.append(f"📄 {item.name} ({size/1024:.1f} KB)")
    return f"Masaüstü ({len(items)} öğe):\n" + "\n".join(items) if items else "Masaüstü boş."

def desktop_control(parameters: dict, response=None, player=None, session_memory=None) -> str:
    action = (parameters or {}).get("action", "").lower().strip()
    task   = (parameters or {}).get("task", "").strip()
    try:
        if action == "wallpaper":
            return _set_wallpaper(parameters.get("path", ""))
        elif action in ("organize", "düzenle"):
            return _organize_desktop_files(parameters.get("mode", "by_type"))
        elif action == "list":
            return _list_desktop()
        elif action == "clean":
            desktop     = Path.home() / "Desktop"
            today       = datetime.now().strftime("%Y-%m-%d")
            archive_dir = desktop / f"Vesper Arşiv {today}"
            archive_dir.mkdir(exist_ok=True)
            moved = 0
            for item in desktop.iterdir():
                if item.is_dir() or item.name.startswith(".") or item.suffix.lower() == ".lnk":
                    continue
                new_path = archive_dir / item.name

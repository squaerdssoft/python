class VesperLive:
    def __init__(self, ui):
        self.ui             = ui
        self.session        = None
        self.audio_in_queue = None
        self.out_queue      = None
        self._loop          = None
        self.vision_watcher = VisionWatcher(self.ui)
        self.ui.core = self

    def _build_config(self):
        return genai_types.LiveConnectConfig(
            response_modalities=["AUDIO"],
            output_audio_transcription={},
            input_audio_transcription={},
            system_instruction=_get_full_prompt(),
            tools=[{"function_declarations": MODULE_DECLARATIONS}],
            session_resumption=genai_types.SessionResumptionConfig(),
            speech_config=genai_types.SpeechConfig(
                voice_config=genai_types.VoiceConfig(
                    prebuilt_voice_config=genai_types.PrebuiltVoiceConfig(voice_name="Puck")
                )
            ),
        )

    async def _execute_tool(self, fc) -> genai_types.FunctionResponse:
        name   = fc.name
        args   = dict(fc.args or {})
        loop   = asyncio.get_event_loop()
        result = "Onaylandı."

        TOOL_MAP = {
            "open_app":          lambda: open_app(parameters=args, player=self.ui),
            "web_search":        lambda: web_search_action(parameters=args, player=self.ui),
            "weather_report":    lambda: weather_action(parameters=args, player=self.ui),
            "send_message":      lambda: send_message(parameters=args, player=self.ui),
            "reminder":          lambda: reminder(parameters=args, player=self.ui),
            "computer_settings": lambda: computer_settings(parameters=args, player=self.ui),
            "youtube_video":     lambda: youtube_video(parameters=args, player=self.ui),
            "desktop_control":   lambda: desktop_control(parameters=args, player=self.ui),
            "browser_control":   lambda: browser_control(parameters=args, player=self.ui),
            "code_helper":       lambda: code_helper(parameters=args, player=self.ui),
            "dev_agent":         lambda: dev_agent(parameters=args, player=self.ui),
            "computer_control":  lambda: computer_control(parameters=args, player=self.ui),
            "file_controller":   lambda: file_controller(parameters=args, player=self.ui),
            "cmd_control":       lambda: cmd_control(parameters=args, player=self.ui),
        }

        try:
            if name in TOOL_MAP:
                r = await loop.run_in_executor(None, TOOL_MAP[name])
                result = r or f"{name} işlendi."
            elif name == "screen_process":
                threading.Thread(
                    target=screen_process,
                    kwargs={"parameters": args, "player": self.ui},
                    daemon=True
                ).start()
                result = "Ekran analizi başlatıldı..."
            elif name == "vision_control":
                mode = args.get("mode", "off")
                self.vision_watcher.active = (mode == "on")
                result = f"Görsel izleme {mode}, efendim."
            else:
                result = f"{name} komutu işlendi."
        except Exception as e:
            result = f"Hata: {e}"

        return genai_types.FunctionResponse(id=fc.id, name=name, response={"result": result})

    async def _send_realtime(self):
        while True:
            msg = await self.out_queue.get()
            if self.session:
                try:
                    await self.session.send_realtime_input(media=msg)
                except Exception:
                    pass

    async def _listen_audio(self):
        logger.info("🎤 Mikrofon aktif")
        pya    = pyaudio.PyAudio()
        stream = await asyncio.to_thread(
            pya.open, format=PA_FORMAT, channels=CHANNELS, rate=SEND_SAMPLE_RATE,
            input=True, frames_per_buffer=CHUNK_SIZE
        )
        try:
            while True:
                data = await asyncio.to_thread(stream.read, CHUNK_SIZE, exception_on_overflow=False)
                # LAF KESME (Barge-in) için mikrofonun her zaman veri göndermesi gerekir.
                # 'if not self.ui.speaking' kontrolünü kaldırıyoruz.
                await self.out_queue.put({"data": data, "mime_type": "audio/pcm"})
        except Exception as e:
            logger.error(f"🎤 Mikrofon hatası: {e}")
            raise
        finally:
            stream.close()
            pya.terminate()

    async def _receive_audio(self):
        logger.info("👂 Alıcı aktif")
        try:
            while True:
                if not self.session:
                    break
                turn = self.session.receive()
                async for response in turn:
                    if not self.session:
                        break
                    if response.data:
                        self.audio_in_queue.put_nowait(response.data)
                    if response.server_content:
                        sc = response.server_content
                        it = getattr(sc, "input_transcription", None) or getattr(sc, "input_audio_transcription", None)
                        if it and it.text:
                            user_text = it.text.lower()
                            logger.info(f"KULLANICI: {it.text}")
                            self.ui.write_log(f"Sen: {it.text}")
                            # LAF KESME (Barge-in manually)
                            if any(word in user_text for word in ["dur", "sus", "anlatım", "yeter", "kes", "iptal", "tamam"]):
                                while not self.audio_in_queue.empty():
                                    self.audio_in_queue.get_nowait()
                                self.ui.stop_speaking()
                                self.ui.write_log("SYS: Anlaşıldı, susuyorum efendim.")
                        ot = getattr(sc, "output_transcription", None) or getattr(sc, "output_audio_transcription", None)
                        if ot and ot.text:
                            logger.info(f"Vesper: {ot.text}")
                            self.ui.write_log(f"Vesper: {ot.text}")
                        if sc.interrupted:
                            while not self.audio_in_queue.empty():
                                self.audio_in_queue.get_nowait()
                            self.ui.stop_speaking()
                            self.ui.write_log("SYS: Kesildi.")
                    if response.tool_call:
                        fn_responses = []
                        for fc in response.tool_call.function_calls:
                            logger.info(f"🔧 Araç: {fc.name}")
                            fr = await self._execute_tool(fc)
                            fn_responses.append(fr)
                        await self.session.send_tool_response(function_responses=fn_responses)
        except Exception as e:
            logger.error(f"👂 Alıcı hatası: {e}")
            traceback.print_exc()

    async def _play_audio(self):
        logger.info("🔊 Hoparlör aktif")
        pya    = pyaudio.PyAudio()
        stream = await asyncio.to_thread(
            pya.open, format=PA_FORMAT, channels=CHANNELS, rate=RECEIVE_SAMPLE_RATE,
            output=True, frames_per_buffer=1024
        )
        try:
            while True:
                if self.audio_in_queue is None:
                    await asyncio.sleep(0.1)
                    continue
                chunk = await self.audio_in_queue.get()
                self.ui.start_speaking()
                await asyncio.to_thread(stream.write, chunk)
                if self.audio_in_queue.empty():
                    self.ui.stop_speaking()
        except Exception as e:
            logger.error(f"🔊 Hoparlör hatası: {e}")
            raise
        finally:
            stream.close()
            pya.terminate()

    async def run_session(self):
        logger.info("🚀 Vesper Neural Hub başlatılıyor...")
        while not self.ui._api_key_ready:
            logger.info("⚠ API anahtarı bekleniyor...")
            await asyncio.sleep(2)

        self.vision_watcher.start()
        ProactiveHeartbeat(self.ui).start()

        while True:
            try:
                self.audio_in_queue = asyncio.Queue()
                self.out_queue      = asyncio.Queue(maxsize=100)
                client = google_genai.Client(api_key=_get_api_key(), http_options={"api_version": "v1alpha"})
                async with (
                    client.aio.live.connect(model=LIVE_MODEL, config=self._build_config()) as session,
                    asyncio.TaskGroup() as tg
                ):
                    self.session = session
                    self._loop   = asyncio.get_event_loop()
                    self.ui.write_log("SYS: Vesper Neural Engine ÇEVRİMİÇİ.")
                    logger.info("✨ Bağlantı kuruldu.")
                    try:
                        await session.send_realtime_input(text="Çevrim içi ve emrinizdeyim, efendim.")
                    except Exception:
                        pass
                    tg.create_task(self._send_realtime())
                    tg.create_task(self._listen_audio())
                    tg.create_task(self._receive_audio())
                    tg.create_task(self._play_audio())
            except Exception as e:
                logger.error(f"❌ Hub çöktü: {e}")
                await asyncio.sleep(2)

    def start(self):
        threading.Thread(target=lambda: asyncio.run(self.run_session()), daemon=True).start()
        self.ui.root.mainloop()


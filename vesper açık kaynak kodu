MAX_FIX_ATTEMPTS = 4

def dev_agent(parameters: dict, response=None, player=None, session_memory=None, speak=None) -> str:
    if not _GENAI:
        return "google-generativeai kurulu değil."
    p            = parameters or {}
    description  = p.get("description", "").strip()
    language     = p.get("language", "python").strip()
    project_name = p.get("project_name", "").strip()
    timeout      = int(p.get("timeout", 30))
    if not description:
        return "Proje açıklaması gerekli, efendim."

    def log(msg: str):
        print(f"[DevAgent] {msg}")
        if player: player.write_log(f"[DevAgent] {msg}")

    genai.configure(api_key=_get_api_key())
    planner = genai.GenerativeModel(GEMINI_MODEL)
    writer  = genai.GenerativeModel(GEMINI_LITE)

    log("Proje yapısı planlanıyor...")
    plan_prompt = (
        f"Proje planla. Dil: {language}. Açıklama: {description}\n\n"
        "Sadece JSON döndür:\n"
        '{"project_name":"ad","entry_point":"main.py","files":[{"path":"main.py","description":"açıklama"}],"run_command":"python main.py","dependencies":["paket"]}'
    )
    try:
        resp = planner.generate_content(plan_prompt)
        raw  = re.sub(r"```(?:json)?", "", resp.text).strip().rstrip("`").strip()
        plan = json.loads(raw)
    except Exception as e:
        return f"Planlama hatası: {e}"

    proj_name   = re.sub(r"[^\w\-]", "_", project_name or plan.get("project_name", "Vesper_project"))
    project_dir = PROJECTS_DIR / proj_name
    project_dir.mkdir(parents=True, exist_ok=True)
    files        = plan.get("files", [])
    entry_point  = plan.get("entry_point", "main.py")
    run_command  = plan.get("run_command", f"python {entry_point}")
    dependencies = plan.get("dependencies", [])

    log(f"Proje: {proj_name} | Dosyalar: {len(files)} | Giriş: {entry_point}")

    file_codes: dict[str, str] = {}
    file_list_str = "\n".join(f"  - {f['path']}: {f['description']}" for f in files)

    for file_info in files:
        file_path = file_info.get("path", "")
        file_desc = file_info.get("description", "")
        if not file_path:
            continue
        log(f"{file_path} yazılıyor...")
        try:
            write_prompt = (
                f"Uzman {language} geliştirici. Proje hedefi: {description}\n"
                f"Tüm dosyalar:\n{file_list_str}\n\n"
                f"Şu dosyayı yaz: {file_path}\nAmacı: {file_desc}\n\n"
                "Sadece kod, açıklama yok:"
            )
            w_resp = writer.generate_content(write_prompt)
            code   = _clean_code(w_resp.text)
            full_p = project_dir / file_path
            full_p.parent.mkdir(parents=True, exist_ok=True)
            full_p.write_text(code, encoding="utf-8")
            file_codes[file_path] = code
            log(f"✅ {file_path}")
        except Exception as e:
            log(f"❌ {file_path}: {e}")

    if not file_codes:
        return "Hiçbir dosya yazılamadı, efendim."

    if dependencies:
        log(f"Bağımlılıklar yükleniyor: {dependencies}")
        try:
            subprocess.run(
                [sys.executable, "-m", "pip", "install"] + dependencies,
                capture_output=True, text=True, timeout=120, cwd=str(project_dir)
            )
        except Exception as e:
            log(f"Bağımlılık hatası: {e}")

    # VSCode aç
    try:
        subprocess.Popen(["code", str(project_dir)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, shell=True)
        time.sleep(2)
    except Exception:
        pass

    # Run & fix
    last_output = ""
    for attempt in range(1, MAX_FIX_ATTEMPTS + 1):
        log(f"Çalıştırılıyor (deneme {attempt}/{MAX_FIX_ATTEMPTS})...")
        parts = run_command.split()
        if parts[0] == "python":
            parts[0] = sys.executable
        try:
            result = subprocess.run(
                parts, capture_output=True, text=True, encoding="utf-8",
                errors="replace", timeout=timeout, cwd=str(project_dir)
            )
            out   = result.stdout.strip()
            err   = result.stderr.strip()
            parts_ = []
            if out: parts_.append(f"Çıktı:\n{out}")
            if err: parts_.append(f"Hata:\n{err}")
            last_output = "\n\n".join(parts_) if parts_ else "Çıktısız çalıştı."
        except subprocess.TimeoutExpired:
            last_output = f"{timeout}s zaman aşımı. (Uzun süreli uygulama çalışıyor olabilir.)"
        except Exception as e:
            last_output = f"Çalıştırma hatası: {e}"

        has_error = any(s in last_output.lower() for s in ["error", "exception", "traceback", "failed"])
        if not has_error or "zaman aşımı" in last_output:
            msg = f"'{proj_name}' projesi çalışıyor, efendim. VSCode'da açıldı: {project_dir}"
            if speak: speak(msg)
            return f"{msg}\n\nÇıktı:\n{last_output}"

        if attempt == MAX_FIX_ATTEMPTS:
            break

        # Hatalı dosyayı bul
        error_file = entry_point
        for fname in file_codes.keys():
            if Path(fname).name in last_output or fname in last_output:
                error_file = fname
                break

        log(f"'{error_file}' dosyasındaki hata düzeltiliyor...")
        try:
            fix_prompt = (
                f"Bu dosyayı düzelt:\n{error_file}\n\n"
                f"Hata:\n{last_output[:2000]}\n\n"
                f"Mevcut kod:\n{file_codes.get(error_file, '')}\n\n"
                "Sadece düzeltilmiş kodu döndür:"
            )
            fix_resp = planner.generate_content(fix_prompt)
            fixed    = _clean_code(fix_resp.text)
            (project_dir / error_file).write_text(fixed, encoding="utf-8")
            file_codes[error_file] = fixed
        except Exception as e:
            log(f"Düzeltme başarısız: {e}")

    msg = f"'{proj_name}' {MAX_FIX_ATTEMPTS} denemede çalıştırılamadı, efendim. Proje: {project_dir}"
    if speak: speak(msg)
    return f"{msg}\n\nSon hata:\n{last_output[:500]}"


MAX_BUILD_ATTEMPTS = 3

def _clean_code(text: str) -> str:
    text = text.strip()
    text = re.sub(r"^```[a-zA-Z]*\n?", "", text)
    text = re.sub(r"\n?```$", "", text)
    return text.strip()

def _resolve_save_path(output_path: str, language: str) -> Path:
    ext_map = {
        "python": ".py", "py": ".py", "javascript": ".js", "js": ".js",
        "typescript": ".ts", "ts": ".ts", "html": ".html", "css": ".css",
        "java": ".java", "cpp": ".cpp", "c": ".c", "bash": ".sh",
        "shell": ".sh", "powershell": ".ps1", "sql": ".sql", "json": ".json",
        "rust": ".rs", "go": ".go",
    }
    if output_path:
        p = Path(output_path)
        return p if p.is_absolute() else Path.home() / "Desktop" / p
    ext = ext_map.get((language or "python").lower(), ".py")
    return Path.home() / "Desktop" / f"Vesper_code{ext}"

def _ch_read_file(file_path: str) -> tuple:
    if not file_path:
        return "", "Dosya yolu belirtilmedi."
    p = Path(file_path)
    if not p.exists():
        return "", f"Dosya bulunamadı: {file_path}"
    try:
        return p.read_text(encoding="utf-8"), ""
    except Exception as e:
        return "", f"Dosya okunamadı: {e}"

def _ch_save_file(path: Path, content: str) -> str:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")
        return f"Kaydedildi: {path}"
    except Exception as e:
        return f"Kaydedilemedi: {e}"

def _ch_has_error(output: str) -> bool:
    return any(s in output.lower() for s in ["error", "exception", "traceback", "syntaxerror", "nameerror", "typeerror", "stderr", "failed"])

def _ch_run_file(path: Path, args: list, timeout: int) -> str:
    interp = {
        ".py": [sys.executable], ".js": ["node"], ".ts": ["ts-node"],
        ".sh": ["bash"], ".ps1": ["powershell", "-File"],
    }.get(path.suffix.lower())
    if not interp:
        return f"Bu uzantı için yorumlayıcı yok: {path.suffix}"
    try:
        result = subprocess.run(
            interp + [str(path)] + (args or []),
            capture_output=True, text=True, encoding="utf-8", errors="replace",
            timeout=timeout, cwd=str(path.parent)
        )
        parts = []
        if result.stdout.strip(): parts.append(f"Çıktı:\n{result.stdout.strip()}")
        if result.stderr.strip(): parts.append(f"Hata:\n{result.stderr.strip()}")
        return "\n\n".join(parts) if parts else "Çıktısız çalıştı."
    except subprocess.TimeoutExpired:
        return f"{timeout}s zaman aşımı."
    except FileNotFoundError:
        return f"Yorumlayıcı bulunamadı: {interp[0]}"
    except Exception as e:
        return f"Çalıştırma hatası: {e}"

def code_helper(parameters: dict, response=None, player=None, session_memory=None, speak=None) -> str:
    if not _GENAI:
        return "google-generativeai kurulu değil."
    p           = parameters or {}
    action      = p.get("action", "write").lower().strip()
    description = p.get("description", "").strip()
    language    = p.get("language", "python").strip()
    output_path = p.get("output_path", "").strip()
    file_path   = p.get("file_path", "").strip()
    code        = p.get("code", "").strip()
    args        = p.get("args", [])
    timeout     = int(p.get("timeout", 30))

    genai.configure(api_key=_get_api_key())
    model = genai.GenerativeModel(GEMINI_MODEL)

    if action == "write":
        if not description:
            return "Ne yazılacağını açıklayın, efendim."
        prompt = (
            f"Sen uzman bir {language} geliştiricisisin.\n"
            f"Şu iş için temiz, çalışan {language} kodu yaz:\n"
            f"{description}\n\nSadece kod, açıklama yok:"
        )
        try:
            resp = model.generate_content(prompt)
            code = _clean_code(resp.text)
            path = _resolve_save_path(output_path, language)
            _ch_save_file(path, code)
            return f"Kod yazıldı. Kaydedildi: {path}\n\nÖnizleme:\n{chr(10).join(code.splitlines()[:10])}"
        except Exception as e:
            return f"Kod yazılamadı: {e}"

    elif action == "run":
        if not file_path:
            return "Çalıştırılacak dosyayı belirtin, efendim."
        p_ = Path(file_path)
        if not p_.exists():
            return f"Dosya bulunamadı: {file_path}"
        return _ch_run_file(p_, args, timeout)

    elif action == "explain":
        if file_path and not code:
            code, err = _ch_read_file(file_path)
            if err:
                return err
        if not code:
            return "Kod veya dosya yolu belirtin, efendim."
        prompt = f"Bu kodun ne yaptığını kısaca açıkla (3-5 cümle):\n\n{code[:4000]}"
        try:
            resp = model.generate_content(prompt)
            return resp.text.strip()
        except Exception as e:
            return f"Açıklama hatası: {e}"

    elif action == "edit":
        if not file_path:
            return "Düzenlenecek dosyayı belirtin, efendim."
        content, err = _ch_read_file(file_path)
        if err:
            return err
        instruction = description or p.get("instruction", "")
        if not instruction:
            return "Değişikliği açıklayın, efendim."
        prompt = (
            f"Bu kodu düzenle:\n{instruction}\n\nOrijinal:\n{content}\n\nSadece güncellenmiş kodu döndür:"
        )
        try:
            resp   = model.generate_content(prompt)
            edited = _clean_code(resp.text)
            _ch_save_file(Path(file_path), edited)
            return f"Dosya düzenlendi: {file_path}\n\nÖnizleme:\n{chr(10).join(edited.splitlines()[:10])}"
        except Exception as e:
            return f"Düzenleme hatası: {e}"

    elif action == "build":
        if not description:
            return "Ne inşa edileceğini açıklayın, efendim."
        lang = language or "python"
        # Write
        try:
            resp = model.generate_content(
                f"Uzman {lang} geliştirici. Şunu yaz:\n{description}\n\nSadece kod:"
            )
            code = _clean_code(resp.text)
            path = _resolve_save_path(output_path, lang)
            _ch_save_file(path, code)
        except Exception as e:
            return f"Başlangıç kodu yazılamadı: {e}"
        # Run & fix loop
        for attempt in range(1, MAX_BUILD_ATTEMPTS + 1):
            out = _ch_run_file(path, args, timeout)
            if not _ch_has_error(out):
                msg = f"İnşaat tamamlandı, efendim. {attempt} denemede çalışıyor. Kaydedildi: {path}"
                if speak: speak(msg)
                return f"{msg}\n\nÇıktı:\n{out}"
            if attempt == MAX_BUILD_ATTEMPTS:
                break
            try:
                fix_resp = model.generate_content(
                    f"Bu kodu düzelt:\nHata: {out[:1000]}\nKod: {code}\n\nDüzeltilmiş kod:"
                )
                code = _clean_code(fix_resp.text)
                _ch_save_file(path, code)
            except Exception:
                break
        msg = f"{MAX_BUILD_ATTEMPTS} denemede çalışan sürüm oluşturulamadı, efendim."
        if speak: speak(msg)
        return msg

    else:
        return f"Bilinmeyen code_helper eylemi: '{action}'"


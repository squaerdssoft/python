def _extract_video_id(url: str) -> str | None:
    match = re.search(r"(?:v=|/v/|youtu\.be/|/embed/|/shorts/)([A-Za-z0-9_-]{11})", url)
    return match.group(1) if match else None

def _is_valid_youtube_url(url: str) -> bool:

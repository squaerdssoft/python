def _resolve_path(raw: str) -> Path:
    shortcuts = {
        "desktop": Path.home() / "Desktop", "downloads": Path.home() / "Downloads",
        "documents": Path.home() / "Documents", "pictures": Path.home() / "Pictures",
        "music": Path.home() / "Music", "videos": Path.home() / "Videos", "home": Path.home(),
        "masaüstü": Path.home() / "Desktop", "indirilenler": Path.home() / "Downloads",
        "belgeler": Path.home() / "Documents",
    }
    lower = raw.strip().lower()
    if lower in shortcuts: return shortcuts[lower]
    return Path(raw).expanduser()

def _format_size(bytes_size: int) -> str:
    for unit in ["B", "KB", "MB", "GB"]:
        if bytes_size < 1024: return f"{bytes_size:.1f} {unit}"
        bytes_size /= 1024
    return f"{bytes_size:.1f} GB"

def file_controller(parameters: dict, response=None, player=None, session_memory=None) -> str:
    action  = (parameters or {}).get("action", "").lower().strip()
    path    = (parameters or {}).get("path", "desktop")
    name    = (parameters or {}).get("name", "")
    content = (parameters or {}).get("content", "")

    def full_path(p: str, n: str) -> Path:
        base = _resolve_path(p)
        return base / n if n else base

    result = "Bilinmeyen eylem."
    try:
        if action == "list":
            target = _resolve_path(path)
            if not target.exists(): return f"Yol bulunamadı: {target}"
            items = []
            for item in sorted(target.iterdir()):
                if item.name.startswith("."): continue
                if item.is_dir(): items.append(f"📁 {item.name}/")
                else:
                    size = _format_size(item.stat().st_size)
                    items.append(f"📄 {item.name} ({size})")
            result = f"{target.name}/ içeriği ({len(items)} öğe):\n" + "\n".join(items) if items else "Boş dizin."

        elif action == "create_file":
            fp = full_path(path, name)
            fp.parent.mkdir(parents=True, exist_ok=True)
            fp.write_text(content, encoding="utf-8")
            result = f"Dosya oluşturuldu: {fp.name}"

        elif action == "create_folder":
            fp = full_path(path, name)
            fp.mkdir(parents=True, exist_ok=True)
            result = f"Klasör oluşturuldu: {fp}"

        elif action == "delete":
            fp = full_path(path, name)
            if not fp.exists(): return f"Bulunamadı: {fp}"
            if _SEND2TRASH:
                send2trash.send2trash(str(fp))
                result = f"Geri dönüşüm kutusuna taşındı: {fp.name}"
            else:
                if fp.is_dir(): shutil.rmtree(fp)
                else: fp.unlink()
                result = f"Kalıcı olarak silindi: {fp.name}"

        elif action == "move":
            fp  = full_path(path, name)
            dst = _resolve_path(parameters.get("destination", "desktop"))
            if not fp.exists(): return f"Kaynak bulunamadı: {fp}"
            if dst.is_dir(): dst = dst / fp.name
            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(fp), str(dst))
            result = f"Taşındı: {fp.name} → {dst.parent.name}/"

        elif action == "copy":
            fp  = full_path(path, name)
            dst = _resolve_path(parameters.get("destination", "desktop"))
            if not fp.exists(): return f"Kaynak bulunamadı: {fp}"
            if dst.is_dir(): dst = dst / fp.name
            dst.parent.mkdir(parents=True, exist_ok=True)
            if fp.is_dir(): shutil.copytree(str(fp), str(dst))
            else: shutil.copy2(str(fp), str(dst))
            result = f"Kopyalandı: {fp.name} → {dst.parent.name}/"

        elif action == "rename":
            fp       = full_path(path, name)
            new_name = parameters.get("new_name", "")
            if not fp.exists(): return f"Bulunamadı: {fp}"
            new_path = fp.parent / new_name
            if new_path.exists(): return f"'{new_name}' adında dosya zaten var."
            fp.rename(new_path)
            result = f"Yeniden adlandırıldı: {fp.name} → {new_name}"

        elif action == "read":
            fp = full_path(path, name)
            if not fp.exists(): return f"Dosya bulunamadı: {fp}"
            content_ = fp.read_text(encoding="utf-8", errors="ignore")
            if len(content_) > 3000: content_ = content_[:3000] + "...(kesildi)"
            result = content_

        elif action == "write":
            fp = full_path(path, name)
            fp.parent.mkdir(parents=True, exist_ok=True)
            mode = "a" if parameters.get("append", False) else "w"
            with open(fp, mode, encoding="utf-8") as f:
                f.write(content)
            result = f"Yazıldı: {fp.name}"

        elif action == "find":
            search_path = _resolve_path(path)
            ext         = parameters.get("extension", "")
            find_name   = name or parameters.get("name", "")
            pattern     = f"*{ext}" if ext else "*"
            results_    = []
            for item in search_path.rglob(pattern):
                if item.is_file():
                    if find_name and find_name.lower() not in item.name.lower(): continue
                    results_.append(f"📄 {item.name} ({_format_size(item.stat().st_size)}) — {item.parent}")
                    if len(results_) >= 20: break
            result = f"{len(results_)} dosya bulundu:\n" + "\n".join(results_) if results_ else "Dosya bulunamadı."

        elif action == "disk_usage":
            target = _resolve_path(path)
            usage  = shutil.disk_usage(target)
            result = (
                f"Disk kullanımı ({target}):\n"
                f"  Toplam: {_format_size(usage.total)}\n"
                f"  Kullanılan: {_format_size(usage.used)} ({usage.used/usage.total*100:.1f}%)\n"
                f"  Boş: {_format_size(usage.free)}"
            )

        elif action == "organize_desktop":
            result = _organize_desktop_files()

        else:
            result = f"Bilinmeyen file_controller eylemi: '{action}'"

    except Exception as e:
        result = f"Dosya kontrolcüsü hatası: {e}"

    if player: player.write_log(f"[file] {result[:60]}")
    return result


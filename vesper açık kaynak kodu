def send_message(parameters: dict, response=None, player=None, session_memory=None) -> str:
    params       = parameters or {}
    receiver     = params.get("receiver", "").strip()
    message_text = params.get("message_text", "").strip()
    platform_    = params.get("platform", "whatsapp").strip().lower()
    if not receiver:
        return "Kime mesaj gönderileceğini belirtin, efendim."
    if not message_text:
        return "Ne yazılacağını belirtin, efendim."
    if player:
        player.write_log(f"[msg] {platform_} → {receiver}")
    if "whatsapp" in platform_ or "wp" in platform_:
        return _send_whatsapp(receiver, message_text)
    elif "telegram" in platform_ or "tg" in platform_:
        return _send_telegram(receiver, message_text)
    elif "instagram" in platform_ or "ig" in platform_:
        return _send_instagram(receiver, message_text)
    else:
        return _send_whatsapp(receiver, message_text)


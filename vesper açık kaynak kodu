class VisionWatcher:
    def __init__(self, ui):
        self.ui     = ui
        self.active = True

    def start(self):
        def loop():
            while self.active:
                try:
                    if _PYAUTOGUI:
                        SENSORY_HUB["visual_context"] = "Windows Masaüstü görünür. Kullanıcı aktif."
                except Exception:
                    pass
                time.sleep(120)
        threading.Thread(target=loop, daemon=True).start()

class ProactiveHeartbeat:
    def __init__(self, ui):
        self.ui = ui

    def start(self):
        def loop():
            while True:
                if _PSUTIL:
                    cpu = psutil.cpu_percent()
                    if cpu > 85:
                        SENSORY_HUB["system_health"] = f"Yüksek Yük (CPU: {cpu}%)"
                        if self.ui: self.ui.write_log(f"UYARI: CPU yükü yüksek ({cpu}%)")
                    else:
                        SENSORY_HUB["system_health"] = "Stabil"
                time.sleep(15)
        threading.Thread(target=loop, daemon=True).start()


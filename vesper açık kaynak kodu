def _detect_cs_action(description: str) -> dict:
    if not _GENAI:
        return {"action": description.lower().replace(" ", "_"), "value": None}
    genai.configure(api_key=_get_api_key())
    model = genai.GenerativeModel(GEMINI_LITE)
    available = ", ".join(sorted(CS_ACTION_MAP.keys())) + ", volume_set, type_text, press_key"
    prompt = (
        f'Kullanıcı bilgisayarını kontrol etmek istiyor.\n'
        f'Kullanıcı dedi (herhangi bir dilde): "{description}"\n'
        f'Mevcut eylemler: {available}\n\n'
        f'YALNIZCA geçerli JSON döndür: {{"action": "eylem_adı", "value": null_veya_değer}}\n'
        f'Örnekler:\n'
        f'- "sesi aç" → {{"action": "volume_up", "value": null}}\n'
        f'- "sesi 60 yap" → {{"action": "volume_set", "value": 60}}\n'
        f'- "ekranı kapat" → {{"action": "sleep_display", "value": null}}\n'
        f'- "bilgisayarı kapat" → {{"action": "shutdown", "value": null}}'
    )
    try:
        response = model.generate_content(prompt)
        text = re.sub(r"```(?:json)?", "", response.text).strip().rstrip("`").strip()
        return json.loads(text)
    except Exception as e:
        logger.warning(f"Eylem tespiti başarısız: {e}")
        return {"action": description.lower().replace(" ", "_"), "value": None}

def computer_settings(parameters: dict, response=None, player=None, session_memory=None) -> str:
    if not _PYAUTOGUI:
        return "pyautogui kurulu değil. pip install pyautogui"
    params      = parameters or {}
    raw_action  = params.get("action", "").strip()
    description = params.get("description", "").strip()
    value       = params.get("value", None)
    if not raw_action and description:
        detected   = _detect_cs_action(description)
        raw_action = detected.get("action", "")
        if value is None:
            value = detected.get("value")
    action = raw_action.lower().strip().replace(" ", "_").replace("-", "_")
    if not action:
        return "Eylem tespit edilemedi, efendim."
    if action == "volume_set":
        try:
            _vol_set(int(value or 50))
            return f"Ses %{value} olarak ayarlandı."
        except Exception as e:
            return f"Ses ayarlanamadı: {e}"
    if action in ("type_text", "write_on_screen", "type", "write"):
        text = str(value or params.get("text", ""))
        if not text:
            return "Yazılacak metin belirtilmedi, efendim."
        if _PYPERCLIP:
            pyperclip.copy(text)
            time.sleep(0.1)
            pyautogui.hotkey("ctrl", "v")
        else:
            pyautogui.write(str(text), interval=0.03)
        return f"Yazıldı: {text[:60]}"
    if action == "press_key":
        key = str(value or params.get("key", ""))
        if not key:
            return "Tuş belirtilmedi, efendim."
        pyautogui.press(key)
        return f"Tuşa basıldı: {key}"
    func = CS_ACTION_MAP.get(action)
    if not func:
        return f"Bilinmeyen eylem: '{raw_action}', efendim."
    try:
        func()
        return f"Tamamlandı: {action}."
    except Exception as e:
        return f"Eylem başarısız ({action}): {e}"


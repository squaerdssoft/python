def web_search_action(parameters: dict, response=None, player=None, session_memory=None) -> str:
    if not _GENAI:
        return "google-generativeai kurulu değil."
    params = parameters or {}
    query  = params.get("query", "").strip()
    if not query:
        return "Arama sorgusu belirtin, efendim."
    if player:
        player.write_log(f"Aranıyor: {query}")
    results = []
    try:
        from duckduckgo_search import DDGS
        with DDGS() as ddgs:
            for r in ddgs.text(query, max_results=8):
                results.append({
                    "title":   r.get("title", ""),
                    "snippet": r.get("body", r.get("snippet", "")),
                    "url":     r.get("href", r.get("link", "")),
                })
    except Exception as e:
        logger.warning(f"DuckDuckGo araması başarısız: {e}")
    if not results:
        return f"'{query}' için sonuç bulunamadı, efendim."
    context = "\n".join([f"- {r['title']}: {r['snippet']} ({r['url']})" for r in results])
    prompt  = (
        f"Sorgu: {query}\n\nArama Sonuçları:\n{context}\n\n"
        "Bu sonuçlara dayanarak kısa, akıllı bir cevap ver. "
        "Kullanıcıya 'efendim' diye hitap et. Maksimum 3-4 cümle."
    )
    try:
        client   = google_genai.Client(api_key=_get_api_key())
        response = client.models.generate_content(model=GEMINI_LITE, contents=prompt)
        return response.text.strip()
    except Exception as e:
        logger.error(f"Gemini özetleme hatası: {e}")
        return "\n".join([f"{r['title']}\n{r['snippet']}\n" for r in results[:3]])


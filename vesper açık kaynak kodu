def _yt_find_thumbnails() -> list:
    if not (_CV2 and _NUMPY and _PYAUTOGUI):
        return []
    try:
        from PIL import ImageGrab
        screenshot = ImageGrab.grab()
        img        = np.array(screenshot)
        screen_h, screen_w = img.shape[:2]
        roi_top    = int(screen_h * 0.10)
        roi_bottom = int(screen_h * 0.75)
        roi_left   = int(screen_w * 0.20)
        roi_right  = int(screen_w * 0.80)
        roi        = img[roi_top:roi_bottom, roi_left:roi_right]
        gray       = cv2.cvtColor(roi, cv2.COLOR_RGB2GRAY)
        edges      = cv2.Canny(gray, 30, 100)
        kernel     = np.ones((3, 3), np.uint8)
        edges      = cv2.dilate(edges, kernel, iterations=2)
        contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        candidates = []
        for c in contours:
            x, y, w, h = cv2.boundingRect(c)
            area  = w * h
            ratio = w / h if h > 0 else 0
            if area < 15000 or not (1.4 < ratio < 2.2):
                continue
            cx_ = x + w // 2 + roi_left
            cy_ = y + h // 2 + roi_top
            candidates.append((cx_, cy_, area))
        filtered = []
        for cx_, cy_, area in sorted(candidates, key=lambda c: c[1]):
            if not any(abs(cx_ - fx) < 80 and abs(cy_ - fy) < 80 for fx, fy in filtered):
                filtered.append((cx_, cy_))
        return filtered
    except Exception as e:
        logger.warning(f"Thumbnail tespiti başarısız: {e}")
        return []

def youtube_video(parameters: dict, response=None, player=None, session_memory=None, speak=None) -> str:
    params = parameters or {}
    action = params.get("action", "play").lower().strip()
    if player:
        player.write_log(f"YouTube: {action}")
    try:
        if action == "play":
            query = params.get("query", "").strip()
            if not query:
                return "Ne izlemek istediğinizi söyleyin, efendim."
            url = f"https://www.youtube.com/results?search_query={query.replace(' ', '+')}"
            webbrowser.open(url)
            time.sleep(2.0)
            thumbnails = _yt_find_thumbnails()
            if len(thumbnails) >= 2:
                x, y = thumbnails[1]
                pyautogui.click(x, y)
                return f"YouTube videosu oynatılıyor: {query}"
            elif len(thumbnails) == 1:
                x, y = thumbnails[0]
                pyautogui.click(x, y)
                return f"YouTube videosu oynatılıyor: {query}"
            else:
                screen_w, screen_h = pyautogui.size()
                pyautogui.click(screen_w // 2, int(screen_h * 0.45))
                return f"YouTube videosu oynatılmaya çalışıldı: {query}"

        elif action == "summarize":
            url = params.get("url", "").strip()
            if not url or not _is_valid_youtube_url(url):
                return "Geçerli bir YouTube URL'si sağlayın, efendim."
            video_id = _extract_video_id(url)
            if not video_id:
                return "Video ID çıkarılamadı, efendim."
            if speak:
                speak("Transkript alınıyor, efendim. Bir dakika.")
            transcript = _get_yt_transcript(video_id)
            if not transcript:
                return "Bu video için transkript bulunamadı, efendim."
            summary = _yt_summarize(transcript)
            if speak:
                speak(summary)
            return summary

        elif action == "trending":
            region = params.get("region", "TR").upper()
            if not _REQUESTS:
                return "requests kütüphanesi kurulu değil."
            url     = f"https://www.youtube.com/feed/trending?gl={region}"
            r       = requests.get(url, headers=YT_HEADERS, timeout=12)
            titles  = re.findall(r'"title":\{"runs":\[\{"text":"([^"]+)"', r.text)
            results = []
            seen    = set()
            for title in titles:
                if title in seen or len(title) < 5:
                    continue
                seen.add(title)
                results.append(f"{len(results)+1}. {title}")
                if len(results) >= 8:
                    break
            return f"Trend ({region}):\n" + "\n".join(results) if results else f"{region} için trend bulunamadı."

        else:
            return f"Bilinmeyen YouTube eylemi: '{action}'"
    except Exception as e:
        return f"YouTube {action} hatası: {e}"

